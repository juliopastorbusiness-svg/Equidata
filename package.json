{
  "name": "equidata",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true});\"",
    "clean:install": "node -e \"const fs=require('fs'); fs.rmSync('node_modules',{recursive:true,force:true}); fs.rmSync('package-lock.json',{force:true});\"",
    "dev": "next dev --webpack -p 3000",
    "dev:turbo": "next dev --turbopack -p 3000",
    "dev:clean": "npm run clean:next && npm run dev",
    "fix:env": "npm run clean:install && npm install && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@stripe/stripe-js": "^9.3.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.8.0",
    "next": "16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
