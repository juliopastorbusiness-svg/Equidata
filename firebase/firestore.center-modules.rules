rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function centerPath(centerId) {
      return /databases/$(database)/documents/centers/$(centerId);
    }

    function memberPath(centerId, uid) {
      return /databases/$(database)/documents/centers/$(centerId)/members/$(uid);
    }

    function userDoc(uid) {
      return get(userPath(uid));
    }

    function centerDoc(centerId) {
      return get(centerPath(centerId));
    }

    function memberDoc(centerId, uid) {
      return get(memberPath(centerId, uid));
    }

    function memberExists(centerId, uid) {
      return exists(memberPath(centerId, uid));
    }

    function requesterMember(centerId) {
      return memberDoc(centerId, request.auth.uid).data;
    }

    function isCenterOwner(centerId) {
      return isSignedIn() && exists(centerPath(centerId)) && (
        centerDoc(centerId).data.ownerId == request.auth.uid ||
        centerDoc(centerId).data.ownerUid == request.auth.uid
      );
    }

    function isCenterStaff(centerId) {
      return isCenterOwner(centerId) || (
        isSignedIn() &&
        memberExists(centerId, request.auth.uid) &&
        requesterMember(centerId).status == "active" &&
        requesterMember(centerId).role in ["center_owner", "center_staff", "CENTER_OWNER", "CENTER_ADMIN"]
      );
    }

    function isActiveMember(centerId) {
      return isSignedIn() &&
        memberExists(centerId, request.auth.uid) &&
        requesterMember(centerId).status == "active";
    }

    function isActiveRider(centerId) {
      return isActiveMember(centerId) &&
        requesterMember(centerId).role in ["rider", "RIDER"];
    }

    function canReadCenter(centerId) {
      return isCenterStaff(centerId) ||
        isActiveMember(centerId) ||
        (isSignedIn() && centerDoc(centerId).data.status == "active");
    }

    function isValidUserProfile() {
      return request.resource.data.uid == request.auth.uid &&
        request.resource.data.role in ["center_owner", "center_staff", "rider", "pro"];
    }

    function isValidCenter() {
      return request.resource.data.name is string &&
        request.resource.data.slug is string &&
        request.resource.data.ownerId is string &&
        request.resource.data.status in ["active", "inactive"];
    }

    function isValidMember() {
      return request.resource.data.userId is string &&
        request.resource.data.role in ["center_owner", "center_staff", "rider", "pro", "CENTER_OWNER", "CENTER_ADMIN", "RIDER", "PRO"] &&
        request.resource.data.status in ["pending", "active", "rejected"];
    }

    function isValidClass() {
      return request.resource.data.title is string &&
        request.resource.data.discipline is string &&
        request.resource.data.level in ["initiation", "basic", "intermediate", "advanced", "competition", "mixed"] &&
        request.resource.data.startAt is timestamp &&
        request.resource.data.endAt is timestamp &&
        request.resource.data.capacity is number &&
        request.resource.data.availableSpots is number &&
        request.resource.data.availableSpots >= 0 &&
        request.resource.data.availableSpots <= request.resource.data.capacity &&
        request.resource.data.status in ["draft", "published", "full", "cancelled", "completed"] &&
        request.resource.data.visibility in ["members_only", "private"] &&
        request.resource.data.bookingMode in ["manual", "request"];
    }

    function isValidReservation() {
      return request.resource.data.classId is string &&
        request.resource.data.riderId is string &&
        request.resource.data.status in ["pending", "confirmed", "cancelled", "completed", "no_show", "RESERVED", "CONFIRMED", "CANCELLED", "COMPLETED", "NO_SHOW"];
    }

    function isValidArena() {
      return request.resource.data.name is string;
    }

    function isValidArenaBooking() {
      return request.resource.data.arenaId is string &&
        request.resource.data.sourceType in ["class", "training", "maintenance", "internal_block"] &&
        request.resource.data.sourceId is string &&
        request.resource.data.title is string &&
        request.resource.data.startAt is timestamp &&
        request.resource.data.endAt is timestamp &&
        request.resource.data.status in ["active", "cancelled", "completed"];
    }

    function isValidEvent() {
      return request.resource.data.title is string &&
        request.resource.data.type in ["CLASS", "TRAINING", "COMPETITION", "VET_REVIEW", "FARRIER", "GENERAL", "INTERNAL_TASK"] &&
        request.resource.data.sourceType in ["class", "training", "competition", "manual"] &&
        request.resource.data.sourceId is string &&
        request.resource.data.startAt is timestamp &&
        request.resource.data.endAt is timestamp &&
        request.resource.data.status in ["SCHEDULED", "CONFIRMED", "CANCELLED", "COMPLETED"];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId);
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUserProfile();
      allow delete: if false;
    }

    match /centers/{centerId} {
      allow read: if canReadCenter(centerId);
      allow create: if isSignedIn() && isValidCenter();
      allow update: if isCenterStaff(centerId) && isValidCenter();
      allow delete: if isCenterOwner(centerId);

      match /members/{memberId} {
        allow read: if isCenterStaff(centerId) || (isSignedIn() && request.auth.uid == memberId);
        allow create: if (
          isCenterStaff(centerId) ||
          (isSignedIn() &&
            request.auth.uid == memberId &&
            request.resource.data.userId == request.auth.uid &&
            request.resource.data.role in ["rider", "RIDER"] &&
            request.resource.data.status == "pending")
        ) && isValidMember();
        allow update: if isCenterStaff(centerId) && isValidMember();
        allow delete: if isCenterOwner(centerId);
      }

      match /classes/{classId} {
        allow read: if isCenterStaff(centerId) || isActiveMember(centerId);
        allow create, update: if isCenterStaff(centerId) && isValidClass();
        allow delete: if isCenterStaff(centerId);
      }

      match /classReservations/{reservationId} {
        allow read: if isCenterStaff(centerId) || (
          isSignedIn() &&
          isActiveMember(centerId) &&
          resource.data.riderId == request.auth.uid
        );
        allow create: if isCenterStaff(centerId) && isValidReservation();
        allow update: if isCenterStaff(centerId) && isValidReservation();
        allow delete: if isCenterStaff(centerId);
      }

      match /arenas/{arenaId} {
        allow read: if isCenterStaff(centerId) || isActiveMember(centerId);
        allow create, update: if isCenterStaff(centerId) && isValidArena();
        allow delete: if isCenterStaff(centerId);
      }

      match /arenaBookings/{bookingId} {
        allow read: if isCenterStaff(centerId) || isActiveMember(centerId);
        allow create, update: if isCenterStaff(centerId) && isValidArenaBooking();
        allow delete: if isCenterStaff(centerId);
      }

      match /events/{eventId} {
        allow read: if isCenterStaff(centerId) || isActiveMember(centerId);
        allow create, update: if isCenterStaff(centerId) && isValidEvent();
        allow delete: if isCenterStaff(centerId);
      }
    }
  }
}
